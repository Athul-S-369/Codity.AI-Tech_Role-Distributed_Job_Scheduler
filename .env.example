# Distributed Job Scheduler — Athul S (RA2311047010117)
# Copy to .env and backend/.env for local development

# Database
DATABASE_URL="postgresql://scheduler:scheduler_secret@localhost:5432/codity_scheduler?schema=public"

# Auth
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"

# API
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"
# RATE_LIMIT_MAX=1000  # production only; worker routes are excluded

# Worker
WORKER_ID=""
WORKER_POLL_INTERVAL_MS=1000
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_MAX_CONCURRENCY=5
WORKER_GRACEFUL_SHUTDOWN_MS=30000
WORKER_REGISTRATION_KEY="dev-worker-register-key"

# Scheduler (dedicated process — default)
SCHEDULER_INTERVAL_MS=5000
# RUN_SCHEDULER_IN_API=true  # only if you want scheduler inside API instead

# Redis (rate limiting & distributed locking — falls back to in-memory if unavailable)
REDIS_URL="redis://localhost:6379"

# AI failure summaries (optional — falls back to regex heuristics)
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_TIMEOUT_MS=8000
